# Telegram bot token from BotFather
BOT_TOKEN=

# PostgreSQL connection string
# On Railway this is set automatically when you add the Postgres add-on
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Stripe payment links (from Stripe Dashboard → Payment Links)
STRIPE_MONTHLY_LINK=https://buy.stripe.com/test_
STRIPE_ANNUAL_LINK=https://buy.stripe.com/test_

# Stripe webhook signing secret (from Stripe Dashboard → Webhooks)
STRIPE_WEBHOOK_SECRET=whsec_

# Port for the webhook HTTP server (Railway sets this automatically)
PORT=8080
